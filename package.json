    "format": "node scripts/format-check.mjs",
    "check": "npm run build && npm run lint && npm test"
  },
  "keywords": [
    "sdd",
    "specification-driven-development",
    "cli",
    "ai",
    "tdd",
    "audit"
  ],
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
