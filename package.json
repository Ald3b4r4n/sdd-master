{
  "name": "sdd-master",
  "version": "0.8.0-rc",
  "description": "SDD Master — specification-driven development framework for AI-assisted software projects",
  "license": "MIT",
  "author": "Mike honor",
  "type": "module",
  "bin": {
    "sdd": "dist/cli/main.js"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "docs/",
    "assets/"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "rc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ald3b4r4n/sdd-master.git"
  },
  "bugs": {
    "url": "https://github.com/Ald3b4r4n/sdd-master/issues"
  },
  "homepage": "https://github.com/Ald3b4r4n/sdd-master#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.mjs",
    "lint": "node scripts/lint.mjs",
    "format": "node scripts/format-check.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "package:check": "node scripts/package-check.mjs",
    "pack:dry-run": "node scripts/pack-dry-run.mjs",
    "release:check": "node scripts/release-check.mjs",
    "check": "npm run build && npm test && npm run lint && npm run format && npm run smoke && npm run package:check && npm run pack:dry-run && npm run release:check"
  },
  "keywords": [
    "sdd",
    "specification-driven-development",
    "ai-agents",
    "cli",
    "typescript",
    "documentation",
    "tdd",
    "audit",
    "traceability",
    "developer-tools"
  ],
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
