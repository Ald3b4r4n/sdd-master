{
  "name": "sdd-master",
  "version": "0.1.0-prototype",
  "description": "SDD Master — specification-driven development framework for AI-assisted software projects",
  "license": "MIT",
  "author": "Mike honor",
  "type": "module",
  "bin": {
    "sdd": "./dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.mjs",
